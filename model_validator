from pydantic import BaseModel, EmailStr, Field, model_validator
from typing import List, Dict, Optional, Annotated

class Patient(BaseModel):
    name: Annotated[str, Field(max_length = 20, title = "Name of the Patient", description = "Enter the name of the Patient")]    
    email: Annotated[Optional[EmailStr], Field(default = None, title = "Patient Mail ID", description = "Enter the email id of the Patient")]
    age: Annotated[int, Field(gt=0, lt = 100, title = "Age of the Patient", description = "Enter the age of the patient")]
    married : Annotated[Optional[bool], Field(default = False, title = "Married", description = "Tell us whether you are married or not")]
    weight: Annotated[int, Field(title = "Weight of the Patient", description = "Enter the weight of the patient")]
    contact_details: Annotated[Dict[str, str], Field(default = "No Contact details", title = "Patient Contact Number", description = "Enter the contact details")]

    @model_validator(mode = 'after')
    def validate_emergency_contact(cls, model):
        if model.age > 60 and 'emergency' not in model.contact_details:
            raise ValueError("patients older then 60 must have an emergency number") 
        return model
    
def update_details(patient:Patient):
    print(patient.name)
