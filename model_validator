from pydantic import BaseModel, EmailStr, Field, model_validator
from typing import Dict, Optional, Annotated

class Patient(BaseModel):
    name: Annotated[str, Field(max_length = 20, title = "Name of the Patient", description = "Enter the name of the Patient")]    
    email: Annotated[Optional[EmailStr], Field(default = None, title = "Patient Mail ID", description = "Enter the email id of the Patient")]
    age: Annotated[int, Field(gt=0, lt = 100, title = "Age of the Patient", description = "Enter the age of the patient")]
    gender: Annotated[str, Field(title = "Gender", description = "Enter the gender of the patient")]
    pan_number: Annotated[Optional[int], Field(default = None, gt=0, lt=100, title = "PanCard Number of patient", description = "Enter the PAN Card Number of Patient")]
    married : Annotated[Optional[bool], Field(default = False, title = "Married", description = "Tell us whether you are married or not")]
    weight: Annotated[int, Field(title = "Weight of the Patient", description = "Enter the weight of the patient")]
    contact_details: Annotated[Dict[str, str], Field(default = "No Contact details", title = "Patient Contact Number", description = "Enter the contact details")]

    @model_validator(mode = 'after')
    def validate_emergency_contact(self) -> 'Patient':
        if self.age > 60 and 'emergency' not in self.contact_details:
            raise ValueError("patients older then 60 must have an emergency number") 
        return self
    
    @model_validator(mode = 'after')
    def validate_name(self) -> 'Patient':
        if self.gender == 'Male' and not self.name.startswith('Mr.'):
            self.name = f"Mr. {self.name}"
        elif self.gender == 'Female' and not self.name.startswith('Ms.'):
            self.name = f"Mrs. {self.name}"
        
        return self 
    
    @model_validator(mode = 'after')
    def validate_pan_number(self) -> 'Patient':
        if self.age > 18 and self.pan_number is None:
            raise ValueError('Patient of 18+ must have a valid PAN Card Number')
        return self
            
    @model_validator(mode = 'after')
    def validate_marriage(self) -> 'Patient':
        if self.gender == 'Female' and self.married == True and not self.name.startswith('Mrs'):
            self.name = f"Mrs. {self.name}"
        return self
    
    @model_validator(mode = 'after')
    def validate_email(self) -> 'Patient':
        if self.age < 18 and self.email is not None:
            raise ValueError(f"Patient {self.name} should not have their personal mail ID")
        return self
    
